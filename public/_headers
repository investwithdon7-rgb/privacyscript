# Cloudflare Pages security headers.
# Applied to every response served by privacyscript.pages.dev and, via the
# Worker, tekdruid.com/privacyscript.
#
# Security decisions documented inline — see CLAUDE.md for compliance mapping.

/*
  # ── Identity / framing ────────────────────────────────────────────────────
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-Permitted-Cross-Domain-Policies: none

  # ── Referrer / privacy ────────────────────────────────────────────────────
  Referrer-Policy: no-referrer

  # ── Capability restrictions ───────────────────────────────────────────────
  # Deny every browser API that has no purpose in a de-identification tool.
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), serial=(), bluetooth=(), nfc=(), screen-wake-lock=(), display-capture=(), window-management=(), idle-detection=(), interest-cohort=()

  # ── Cross-origin isolation ────────────────────────────────────────────────
  # COOP + COEP enable SharedArrayBuffer (needed by Tesseract WASM threads).
  # CORP: same-origin prevents cross-origin reads of our responses.
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Resource-Policy: same-origin

  # ── CORS — replace Cloudflare Pages default ACAO: * ──────────────────────
  # No cross-origin code should be able to read responses from this health tool.
  # The Worker also enforces this; belt-and-braces for direct pages.dev access.
  Access-Control-Allow-Origin: https://tekdruid.com

  # ── Transport security ────────────────────────────────────────────────────
  # 2 years, includeSubDomains, preload-eligible.
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # ── Content Security Policy ───────────────────────────────────────────────
  # wasm-unsafe-eval    — required by Transformers.js / Tesseract ONNX WASM.
  #                       Chrome 95+ separates wasm-unsafe-eval from unsafe-eval;
  #                       this is the minimal grant needed for in-browser NER.
  # unsafe-inline (CSS) — required by Tailwind's runtime class generation.
  # unsafe-inline (JS)  — fallback for direct privacyscript.pages.dev access.
  #                       Next.js App Router emits inline <script> tags for RSC
  #                       hydration (self.__next_f.push(…)); without them the
  #                       page renders as static HTML and buttons do not respond.
  #                       On the public tekdruid.com URL the Cloudflare Worker
  #                       REPLACES unsafe-inline with a per-request nonce, so the
  #                       production surface is strictly nonce-only.
  # huggingface.co      — first-load NER model download only (cached IndexedDB).
  # *.xethub.hf.co     — HuggingFace XetHub CAS storage (new CDN infra, e.g.
  #                       cas-bridge.xethub.hf.co) used for model file chunks.
  # *.hf.co            — HuggingFace shortlink domain; covers future HF hosts.
  # cdn.jsdelivr.net   — Tesseract.js language data (.traineddata) fetched on
  #                       first OCR use and cached in IndexedDB thereafter.
  #                       worker.min.js + core WASM are self-hosted (script-src
  #                       'self'); only the traineddata fetch needs this origin.
  # upgrade-insecure-requests — forces any accidental http:// ref to https://.
  # block-all-mixed-content   — belt-and-braces against mixed content.
  #
  # NOTE: data: was previously in connect-src to allow Emscripten's SINGLE_FILE
  # WASM fetch from a data URI. That approach also failed under COEP require-corp
  # (data: URIs are opaque-origin and cannot carry CORP headers). The build script
  # now patches the WASM loaders to fetch from a same-origin absolute URL instead,
  # so data: is no longer needed in connect-src.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://huggingface.co https://cdn-lfs.huggingface.co https://cdn-lfs-us-1.huggingface.co https://*.xethub.hf.co https://*.hf.co https://cdn.jsdelivr.net; worker-src 'self' blob:; child-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'; upgrade-insecure-requests; block-all-mixed-content

  # ── Caching — default no-store for all pages ─────────────────────────────
  # Health tool — page HTML must never be cached in the browser (shared device
  # risk). The more-specific /_next/static/* and /pdf.worker.min.mjs rules
  # below override this to immutable for content-hashed static assets.
  # HIPAA §164.530(c), GDPR Art. 32.
  Cache-Control: no-store, no-cache
  Pragma: no-cache

# ── Immutable static assets ───────────────────────────────────────────────────
# Next.js content-hashes every file under _next/static/. The filename changes
# when the content changes, so a one-year immutable cache is safe and fast.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# pdf.js worker is also content-stable once deployed.
/pdf.worker.min.mjs
  Cache-Control: public, max-age=31536000, immutable

# ORT WASM binaries — large (~10 MB each), content-stable for a given
# onnxruntime-web version. Cache one day so any ort upgrade redeploys cleanly.
/wasm/*.wasm
  Cache-Control: public, max-age=86400

# Tesseract.js self-hosted assets — worker bootstrap + core WASM loaders.
# These are copied from node_modules at build time (scripts/copy-tesseract-assets.js)
# and are content-stable for a given tesseract.js / tesseract.js-core version.
# Cache one day so a tesseract.js upgrade picks up new files cleanly on next deploy.
/tesseract/*.js
  Cache-Control: public, max-age=86400

/tesseract/*.wasm
  Cache-Control: public, max-age=86400
